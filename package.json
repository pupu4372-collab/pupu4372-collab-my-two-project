{
  "name": "k-saju-pet",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "next dev",
    "dev:clean": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true})}catch(e){}\" && next dev",
    "build": "next build",
    "prestart": "node scripts/free-port.mjs",
    "start": "next start",
    "start:clean": "node scripts/free-port.mjs && next start",
    "lint": "next lint",
    "test:pdf": "tsx scripts/test-human-premium-pdf.ts",
    "test:hybrid": "tsx scripts/test-human-premium-hybrid.ts",
    "test:human-ziwei": "tsx scripts/test-human-ziwei.ts",
    "test:ksaju-mapping": "tsx scripts/test-ksaju-mapping.ts",
    "test:pillar-regression": "tsx scripts/test-pillar-regression.ts",
    "test:luck-pillars": "tsx scripts/test-luck-pillars.ts",
    "test:llm-cache-keys": "tsx scripts/test-llm-cache-keys.ts",
    "test:llm-cache-db": "tsx scripts/test-llm-cache-db.ts",
    "db:apply-community": "node scripts/apply-community-migrations.mjs",
    "db:apply-breed-guides": "node scripts/apply-breed-guide-migrations.mjs",
    "stitch:localize": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/localize-stitch-images.ps1",
    "stitch:localize-html": "node scripts/localize-stitch-html.mjs",
    "stitch:copy-public": "node scripts/copy-stitch-public.mjs",
    "favicons:generate": "node scripts/generate-favicons.mjs",
    "prebuild": "node scripts/generate-favicons.mjs",
    "cap:sync": "cap sync",
    "cap:open:android": "cap open android",
    "cap:open:ios": "cap open ios",
    "android:bundle": "cap sync android && cd android && gradlew.bat bundleRelease",
    "vercel:deploy": "vercel deploy --prod",
    "cf-build": "opennextjs-cloudflare build && node scripts/cf-postbuild.mjs",
    "cf-deploy": "opennextjs-cloudflare build && node scripts/cf-postbuild.mjs && opennextjs-cloudflare deploy",
    "cf-preview": "opennextjs-cloudflare build && node scripts/cf-postbuild.mjs && opennextjs-cloudflare preview"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "@capacitor/app": "^7.1.2",
    "@capacitor/camera": "^7.0.5",
    "@capacitor/core": "^7.6.5",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/share": "^8.0.1",
    "@capacitor/splash-screen": "^7.0.5",
    "@capacitor/status-bar": "^7.0.6",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.49.8",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "browser-image-compression": "^2.0.2",
    "capacitor-kakao-login-plugin": "^3.0.0",
    "html2canvas": "^1.4.1",
    "lunar-javascript": "^1.7.7",
    "next": "^15.3.2",
    "next-intl": "^4.12.0",
    "openai": "^6.44.0",
    "pdfmake": "^0.3.10",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@capacitor/android": "^7.6.5",
    "@capacitor/cli": "^7.6.5",
    "@capacitor/ios": "^7.6.5",
    "@opennextjs/cloudflare": "^1.19.11",
    "@types/node": "^22.15.21",
    "@types/pdfmake": "^0.3.3",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "eslint": "^9.27.0",
    "eslint-config-next": "^15.3.2",
    "pg": "^8.21.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "to-ico": "^1.1.5",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3",
    "wrangler": "^4.93.1"
  }
}
