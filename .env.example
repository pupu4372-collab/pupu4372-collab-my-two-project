# Supabase (https://supabase.com/dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only (API routes, admin); never expose to browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Database password (Project Settings → Database) — for local migration scripts only
# SUPABASE_DB_PASSWORD=your-database-password

# Kakao JavaScript SDK (fortune share)
# NEXT_PUBLIC_KAKAO_JS_KEY=

# Home fortune care calendar reminders (set true after pet_care_events migration)
# NEXT_PUBLIC_CARE_REMINDERS=true

# Instagram Stories iOS source_application (optional)
# NEXT_PUBLIC_FACEBOOK_APP_ID=

# Local dev: omit or use your actual dev port. API routes prefer the request origin on localhost.
NEXT_PUBLIC_APP_URL=https://ksajupet.com

# Capacitor WebView URL
CAPACITOR_SERVER_URL=https://ksajupet.com

# Mobile app: add these Supabase redirect URLs when testing Capacitor:
# https://ksajupet.com/auth/callback
# https://ksajupet.com/auth/reset-password

# PayPal (premium saju reports — omit for demo checkout)
# PAYPAL_MODE=sandbox
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=

# Resend (human premium report email delivery)
# RESEND_API_KEY=
# REPORT_EMAIL_FROM=K-Saju Pet <noreply@ksajupet.com>

# Gemini AI narrative generation (server-only; optional)
# Get a key from Google AI Studio: https://aistudio.google.com/apikey
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
