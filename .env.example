# Supabase (https://supabase.com/dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only (API routes, admin); never expose to browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Database password (Project Settings → Database) — for local migration scripts only
# SUPABASE_DB_PASSWORD=your-database-password

# Kakao JavaScript SDK (fortune share)
# NEXT_PUBLIC_KAKAO_JS_KEY=

# Home fortune care calendar reminders (default on; set false to disable)
# NEXT_PUBLIC_CARE_REMINDERS=false

# Instagram Stories iOS source_application (optional)
# NEXT_PUBLIC_FACEBOOK_APP_ID=

# Local dev: omit or use your actual dev port. API routes prefer the request origin on localhost.
NEXT_PUBLIC_APP_URL=https://ksajupet.com

# Capacitor WebView URL
CAPACITOR_SERVER_URL=https://ksajupet.com

# Mobile app: add these Supabase redirect URLs when testing Capacitor:
# https://ksajupet.com/auth/callback
# https://ksajupet.com/auth/reset-password

# PortOne V2 (human premium KRW checkout)
# PORTONE_SHOP_ID=
# PORTONE_API_SECRET=

# PayPal hosted payment links (/premium/human — dashboard에서 생성한 링크 URL)
# PAYPAL_LINK_DEFAULT=https://www.paypal.com/ncp/payment/...
# PAYPAL_LINK_LIFETIME=
# PAYPAL_LINK_DAILY=
# PAYPAL_LINK_WEEKLY=
# PAYPAL_LINK_MONTHLY=
# PAYPAL_LINK_YEARLY=
# PAYPAL_LINK_MENTAL=
# PAYPAL_LINK_LOVE=
# PAYPAL_LINK_CAREER=
# PAYPAL_LINK_BUSINESS=
# PAYPAL_LINK_WEALTH=
# PAYPAL_LINK_BUNDLE_ALL=
# PAYPAL_LINK_BUNDLE_THEMEPACK=
# PAYPAL_LINK_BUNDLE_TIMEPACK=

# Human premium demo checkout (0/false = disable in production)
# HUMAN_PREMIUM_DEMO_CHECKOUT=1

# Resend (human premium report email delivery)
# RESEND_API_KEY=
# REPORT_EMAIL_FROM=K-Saju Pet <jungho@ksajupet.com>

# Gemini AI narrative generation (server-only; optional fallback)
# Get a key from Google AI Studio: https://aistudio.google.com/apikey
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

# Pet/human saju LLM interpretation (Claude primary, OpenAI fallback)
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# LLM verbose debug logs ([CLAUDE_CALL_*], [LLM_CACHE_*], raw response tails). Failures always log.
# LLM_DEBUG=0

# LLM result cache (Supabase saju_llm_cache — requires service role + migration 028)
# LLM_CACHE=1
# LLM_CACHE_TTL_DAYS=90

# Upstash Redis (rate limiting — /api/saju/basic, 5 req/hour per IP)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
